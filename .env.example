# ─── Application ─────────────────────────────────────────
APP_ENV=development
APP_NAME=cv-intel-rag
LOG_LEVEL=INFO

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/cv_intel.db

# ─── Storage ─────────────────────────────────────────────
CHROMA_PATH=./data/chroma
RAW_PAYLOAD_ROOT=./data/raw

# ─── LLM Provider ────────────────────────────────────────
# Options: typhoon_api | vllm_local | openai_compat | null
DEFAULT_LLM_PROVIDER=typhoon_api

# Typhoon (SCB 10X) — default, free tier available
# Get API key: https://playground.opentyphoon.ai/settings/api-key
TYPHOON_API_KEY=
TYPHOON_BASE_URL=https://api.opentyphoon.ai/v1
TYPHOON_MODEL=typhoon-v2.5-30b-a3b-instruct

# vLLM self-host (run: vllm serve scb10x/typhoon-v2.5-30b-a3b-instruct --port 8000)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=scb10x/typhoon-v2.5-30b-a3b-instruct

# Generic OpenAI-compatible (OpenThai, Pathumma, etc.)
# OPENAI_COMPAT_API_KEY=
# OPENAI_COMPAT_BASE_URL=https://example.com/v1
# OPENAI_COMPAT_MODEL=model-name

# Generation parameters
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=8192
LLM_TIMEOUT_SEC=60

# ─── Embedding ───────────────────────────────────────────
# BGE-M3: supports Thai + English + 100+ languages, 8192 tokens context
EMBED_MODEL_NAME=BAAI/bge-m3
EMBED_DEVICE=cpu                 # change to 'cuda' on GPU box
EMBED_BATCH_SIZE=16

# ─── RAG retrieval ───────────────────────────────────────
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=80
RETRIEVE_TOP_K=8
RETRIEVE_ALPHA=0.6               # dense vs BM25 (0=BM25 only, 1=dense only)

# ─── Data source API keys (optional, for higher rate limits) ─
NCBI_API_KEY=
NCBI_EMAIL=
OPENFDA_API_KEY=
